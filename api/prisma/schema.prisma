datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ALIEN
  SCIENTIST
}

model Game {
  id        String   @id() @default(uuid())
  roomCode  String   @unique()
  alienCode Json
  players   Player[]
}

model Player {
  id       String @id() @default(uuid())
  name     String
  password String
  gameId   String
  role     Role
  game     Game   @relation(fields: [gameId], references: [id])
}
